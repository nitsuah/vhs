# Web UI port (default 8080)
APP_PORT=8080

# Vision model to pull and use (pulled automatically on first run)
OLLAMA_MODEL=llava:7b

# Ollama endpoint used by the nginx proxy.
# Default: Docker sidecar (CPU only).
# For GPU: set to native Windows Ollama (requires Ollama installed + running on the host).
#   AMD iGPU/dGPU: Ollama uses DirectML automatically on Windows.
#   NVIDIA: also works natively on Windows with CUDA.
OLLAMA_UPSTREAM=http://ollama:11434
# OLLAMA_UPSTREAM=http://host.docker.internal:11434
