# Web UI port (default 8080)
APP_PORT=8080

# ── HTTPS / mobile camera access ─────────────────────────────────────────────
# Set to your machine's LAN IP so the auto-generated TLS cert covers it.
# Then open http://<HOST_IP>:8082/ca.crt on your phone to install the CA cert,
# and use https://<HOST_IP>:8443 for camera access.
# If your IP changes, delete the certs volume and restart: docker volume rm vhs_certs
HOST_IP=192.168.1.171

# Vision model to pull and use (pulled automatically on first run)
OLLAMA_MODEL=llava:7b

# ── Neon PostgreSQL ──────────────────────────────────────────────────────────
# Get your connection string from https://console.neon.tech
DATABASE_URL=postgresql://user:password@host.neon.tech/vhs?sslmode=require

# ── GPU / native Ollama ──────────────────────────────────────────────────────
# By default the app uses the bundled Docker Ollama sidecar (CPU only).
#
# To use native Windows Ollama with AMD DirectML or NVIDIA GPU:
#   1. Install Ollama from https://ollama.com and start it.
#   2. Pull the model:  ollama pull llava:7b
#   3. Start with the gpu profile instead of the default:
#        docker compose --profile gpu up web-gpu
#   The web-gpu service proxies /api/ollama → host.docker.internal:11434.
#
OLLAMA_UPSTREAM=http://ollama:11434
# OLLAMA_UPSTREAM=http://host.docker.internal:11434
